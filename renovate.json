{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchPackageNames": [
        "renovate-shared-utils"
      ],
      "groupName": "renovate-shared-utils updates",
      "rangeStrategy": "bump",
      "labels": [
        "dependencies",
        "shared-utils"
      ]
    }
  ]
}
